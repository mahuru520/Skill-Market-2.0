{
  "id": "official/invoice-ocr",
  "name": "invoice-ocr",
  "display_name": "发票 OCR 识别",
  "description": "调用 Dify 批量识别发票并导出 CSV。当用户请求发票识别、批量提取发票信息、导出 CSV 时触发。",
  "version": "2.0.0",
  "icon": "🧾",
  "category": "code_debug",
  "source": "osprey",
  "runtime_type": "gateway_migrated_api",
  "owner": {
    "name": "official",
    "type": "official",
    "verified": true,
    "avatar": "🏢",
    "url": ""
  },
  "readme": "SKILL.md",
  "files": [],
  "env_vars": [
    {
      "key": "GW",
      "description": "外网网关地址",
      "required": true,
      "source": "固定 https://ai.ospreyai.cn",
      "example": "https://ai.ospreyai.cn"
    },
    {
      "key": "API_KEY",
      "description": "网关 new-api key",
      "required": true,
      "source": "网关控制台申请",
      "example": "sk-xxx"
    },
    {
      "key": "DIFY_TOKEN",
      "description": "Dify 后端 token",
      "required": true,
      "source": "Dify 应用 API Key",
      "example": "app-xxx"
    }
  ],
  "api": {
    "base_url": "https://ai.ospreyai.cn",
    "auth_type": "gateway_plus_backend",
    "endpoints": [
      {
        "method": "POST",
        "path": "/api/v1/ai/workflow/files/upload",
        "desc": "上传发票 PDF/图片"
      },
      {
        "method": "POST",
        "path": "/api/v1/ai/workflow/workflows/run",
        "desc": "运行发票识别工作流（blocking，timeout 300s）"
      },
      {
        "method": "GET",
        "path": "/api/v1/ai/workflow/workflows/tasks/{task_id}",
        "desc": "异步任务状态查询"
      },
      {
        "method": "GET",
        "path": "/api/v1/ai/workflow/parameters",
        "desc": "获取工作流入参表单"
      }
    ],
    "rate_limit": "10/min/IP burst 5",
    "timeout_sec": 300
  },
  "migration": {
    "migrated_from": "http://192.168.1.236/v1",
    "migrated_to": "https://ai.ospreyai.cn",
    "behavior_change": "上传改 POST /api/v1/ai/workflow/files/upload，运行改 POST /api/v1/ai/workflow/workflows/run（注意 workflow 出现两次），均经网关。鉴权改为网关 Authorization + 后端 X-Authorization 双 token。批量发票易触发限流，需串行 + 退避。输出落盘（result/md、result/json、result/invoices.csv）保持不变。已实测上传/提交链路通（status 返回 succeeded/failed 取决于后端节点执行）。",
    "status": "verified"
  },
  "platform": {
    "host": "openclaw",
    "min_version": "1.0",
    "capabilities": [
      "skill-install"
    ]
  },
  "changelog": [
    {
      "version": "2.0.0",
      "date": "2026-06-25",
      "changes": [
        "内网 Dify 迁移至外网网关",
        "双 token 鉴权",
        "批量限流退避",
        "上传/提交链路实测通过"
      ],
      "type": "MAJOR"
    }
  ],
  "created_at": "2026-01-01T00:00:00Z",
  "updated_at": "2026-06-25T00:00:00Z",
  "quickstart": {
    "overview": "批量识别发票，提取信息并导出CSV",
    "scenarios": [
      "财务人员批量处理纸质发票电子化",
      "企业发票信息快速提取与归档",
      "审计或报销流程中发票数据自动化录入"
    ],
    "example": "帮我把这些发票里的信息识别出来，生成一个CSV表格。",
    "notes": "需配置双Token鉴权，注意API路径为两层workflow"
  }
}
